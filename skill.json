{
  "name": "weread-to-flomo",
  "version": "0.1.0",
  "description": "Agent Skill that exports WeRead (微信读书) highlights and thoughts to flomo via the flomo MCP server.",
  "type": "agent-skill",
  "language": "zh-CN",
  "skills": [
    {
      "name": "weread-to-flomo",
      "entry": "skill/weread-to-flomo/SKILL.md",
      "files": [
        "skill/weread-to-flomo/SKILL.md",
        "skill/weread-to-flomo/workflow.md",
        "skill/weread-to-flomo/format.md",
        "skill/weread-to-flomo/dedup.md"
      ]
    }
  ],
  "install": {
    "default_target": "~/.agents/skills/",
    "bin": "bin/install.js",
    "via_npx": [
      "npx skills huangcheng/weread-to-flomo",
      "npx weread-to-flomo"
    ]
  },
  "depends_on": {
    "agent_skills": [
      {
        "name": "weread-skills",
        "source": "https://cdn.weread.qq.com/skills/weread-skills.zip",
        "purpose": "Read WeRead highlights/notes/reviews via Agent API gateway"
      }
    ],
    "mcp_servers": [
      {
        "name": "flomo",
        "url": "https://flomoapp.com/mcp",
        "transport": "streamable-http",
        "tools_used": ["memo_create", "memo_search", "get_format_guide"]
      }
    ],
    "env_vars": [
      {
        "name": "WEREAD_API_KEY",
        "format": "wrk-xxxx",
        "required_by": "weread-skills"
      }
    ]
  },
  "supported_tools": [
    "claude-code",
    "codex",
    "opencode",
    "gemini-cli",
    "qoder"
  ],
  "repository": "https://github.com/huangcheng/weread-to-flomo",
  "homepage": "https://github.com/huangcheng/weread-to-flomo#readme",
  "license": "MIT"
}
